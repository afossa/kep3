{
  "version": 10,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "environment": {
        "CONDA_PREFIX": "${sourceDir}/.pixi/envs/default"
      },
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "$env{CONDA_PREFIX}",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{CONDA_PREFIX}",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "kep3_BUILD_TESTS": "ON",
        "kep3_BUILD_PYTHON_BINDINGS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Clang)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "$env{CONDA_PREFIX}/bin/clang",
        "CMAKE_CXX_COMPILER": "$env{CONDA_PREFIX}/bin/clang++"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Clang)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "$env{CONDA_PREFIX}/bin/clang",
        "CMAKE_CXX_COMPILER": "$env{CONDA_PREFIX}/bin/clang++"
      }
    },
    {
      "name": "debug-gcc",
      "displayName": "Debug (GCC)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "$env{CONDA_PREFIX}/bin/gcc",
        "CMAKE_CXX_COMPILER": "$env{CONDA_PREFIX}/bin/g++"
      }
    },
    {
      "name": "release-gcc",
      "displayName": "Release (GCC)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "$env{CONDA_PREFIX}/bin/gcc",
        "CMAKE_CXX_COMPILER": "$env{CONDA_PREFIX}/bin/g++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug (Clang)",
      "configurePreset": "debug",
      "configuration": "Debug",
      "jobs": 0
    },
    {
      "name": "release",
      "displayName": "Build Release (Clang)",
      "configurePreset": "release",
      "configuration": "Release",
      "jobs": 0
    },
    {
      "name": "debug-gcc",
      "displayName": "Build Debug (GCC)",
      "configurePreset": "debug-gcc",
      "configuration": "Debug",
      "jobs": 0
    },
    {
      "name": "release-gcc",
      "displayName": "Build Release (GCC)",
      "configurePreset": "release-gcc",
      "configuration": "Release",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "displayName": "Test Debug (Clang)",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false,
        "jobs": 0
      }
    },
    {
      "name": "release",
      "displayName": "Test Release (Clang)",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false,
        "jobs": 0
      }
    },
    {
      "name": "debug-gcc",
      "displayName": "Test Debug (GCC)",
      "configurePreset": "debug-gcc",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false,
        "jobs": 0
      }
    },
    {
      "name": "release-gcc",
      "displayName": "Test Release (GCC)",
      "configurePreset": "release-gcc",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false,
        "jobs": 0
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "debug",
      "displayName": "Full Debug Workflow (Clang)",
      "steps": [
        {
          "type": "configure",
          "name": "debug"
        },
        {
          "type": "build",
          "name": "debug"
        },
        {
          "type": "test",
          "name": "debug"
        }
      ]
    },
    {
      "name": "release",
      "displayName": "Full Release Workflow (Clang)",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        },
        {
          "type": "test",
          "name": "release"
        }
      ]
    },
    {
      "name": "debug-gcc",
      "displayName": "Full Debug Workflow (GCC)",
      "steps": [
        {
          "type": "configure",
          "name": "debug-gcc"
        },
        {
          "type": "build",
          "name": "debug-gcc"
        },
        {
          "type": "test",
          "name": "debug-gcc"
        }
      ]
    },
    {
      "name": "release-gcc",
      "displayName": "Full Release Workflow (GCC)",
      "steps": [
        {
          "type": "configure",
          "name": "release-gcc"
        },
        {
          "type": "build",
          "name": "release-gcc"
        },
        {
          "type": "test",
          "name": "release-gcc"
        }
      ]
    }
  ]
}